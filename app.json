{
  "expo": {
    "name": "Cycle Care",
    "slug": "kalebi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cycleapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "buildNumber": "2",
      "infoPlist": {
        "NSFaceIDUsageDescription": "აპლიკაციაში სწრაფად და უსაფრთხოდ შესასვლელად გამოიყენება Face ID.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.mishvela.kalebi"
    },
   "android": {
  "package": "com.mishvela.kalebi",
  "versionCode": 2, // აუცილებელია Play Store-ისთვის (უნდა გაიზარდოს ყოველ Build-ზე)
  "adaptiveIcon": {
    "foregroundImage": "./assets/images/android-icon-foreground.png",
    "backgroundImage": "./assets/images/android-icon-background.png", // ან გამოიყენე "backgroundColor": "#fff0f5"
    "backgroundColor": "#fff0f5"
  },
  "edgeToEdgeEnabled": true,
  "predictiveBackGestureEnabled": false,
  "permissions": [
    "android.permission.USE_BIOMETRIC",
    "android.permission.USE_FINGERPRINT",
    "android.permission.POST_NOTIFICATIONS" // აუცილებელია შეტყობინებებისთვის Android 13+ ზე
  ]
},
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "imageWidth": 220,
          "backgroundColor": "#fff0f5",
          "dark": {
            "backgroundColor": "#fff0f5"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-notifications",
      "expo-secure-store",
      "expo-local-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "90082f78-6f14-4632-9c3f-7a609964a196"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "owner": "mishvela",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/90082f78-6f14-4632-9c3f-7a609964a196"
    }
  }
}
